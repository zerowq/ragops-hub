APP_NAME=RAGOps Hub
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATA_DIR=./data
MAX_UPLOAD_BYTES=20971520

# demo: editable identity headers; jwt: signed Authorization Bearer token
AUTH_MODE=demo
JWT_SECRET=replace-in-production
JWT_ALGORITHM=HS256

# memory: zero-infrastructure demo; milvus: external Milvus service
VECTOR_BACKEND=memory
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=ragops_knowledge_v1

# hash: deterministic offline embedding; openai: OpenAI-compatible endpoint
EMBEDDING_PROVIDER=hash
EMBEDDING_DIMENSION=384
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4.1-mini

TOP_K_DENSE=8
TOP_K_SPARSE=8
TOP_K_FINAL=5
MIN_DENSE_SCORE=0.15
MIN_LEXICAL_OVERLAP=0.15
CHUNK_SIZE=500
CHUNK_OVERLAP=80
RRF_K=60
LLM_ENABLED=false

# Case-scoped conversation memory. Business facts still come from CRM/order tables.
MEMORY_RECENT_MESSAGES=8
MEMORY_SUMMARY_TRIGGER_MESSAGES=12
MEMORY_SUMMARY_MAX_CHARS=1600
