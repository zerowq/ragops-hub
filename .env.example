APP_NAME=EnterpriseRAG Agent Hub
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATA_DIR=./data

# memory: zero-infrastructure demo; milvus: external Milvus service
VECTOR_BACKEND=memory
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_COLLECTION=enterprise_knowledge

# hash: deterministic offline embedding; openai: OpenAI-compatible endpoint
EMBEDDING_PROVIDER=hash
EMBEDDING_DIMENSION=384
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4.1-mini

TOP_K_DENSE=8
TOP_K_SPARSE=8
TOP_K_FINAL=5
CHUNK_SIZE=500
CHUNK_OVERLAP=80
RRF_K=60
LLM_ENABLED=false

